<style>
  *{box-sizing:border-box;margin:0;padding:0;}
  :root{--sky:#38BDF8;--violet:#8B5CF6;--green:#34D399;--amber:#FBBF24;--red:#F87171;--slate:#64748b;--text:#EAF1FB;--soft:rgba(234,241,251,.62);--dim:rgba(234,241,251,.4);--line:rgba(255,255,255,.1);}
  body{font-family:'Inter',sans-serif;background:radial-gradient(ellipse 90% 55% at 50% -10%,#10213c,#070E1B);color:var(--text);min-height:100vh;padding:30px;}
  h1{font-family:'Bricolage Grotesque',sans-serif;font-size:28px;font-weight:800;letter-spacing:-.02em;margin-top:6px;}
  .brand{font-weight:800;font-size:14px;} .brand span{color:var(--sky);}
  .sub{color:var(--soft);font-size:13px;margin:4px 0 22px;}
  .legend{display:flex;gap:16px;flex-wrap:wrap;font-size:12px;color:var(--soft);margin-bottom:18px;}
  .legend span{display:inline-flex;align-items:center;gap:6px;}
  .sw{width:12px;height:12px;border-radius:3px;}
  .chart{border:1px solid var(--line);border-radius:16px;overflow:hidden;background:rgba(255,255,255,.02);}
  .months{display:grid;grid-template-columns:170px repeat(7,1fr);border-bottom:1px solid var(--line);}
  .months div{padding:11px 8px;font-size:12px;font-weight:600;color:var(--soft);text-align:center;border-left:1px solid var(--line);}
  .months div:first-child{border-left:0;text-align:left;color:var(--dim);font-size:11px;letter-spacing:.08em;text-transform:uppercase;}
  .months .launchcol{color:#fca5a5;}
  .lane{display:grid;grid-template-columns:170px 1fr;border-bottom:1px solid var(--line);}
  .lane:last-child{border-bottom:0;}
  .lane-label{padding:12px 10px;font-size:12.5px;font-weight:600;display:flex;align-items:center;gap:8px;}
  .lane-label .d{width:9px;height:9px;border-radius:50%;flex:none;}
  .track{position:relative;display:grid;grid-template-columns:repeat(7,1fr);grid-auto-rows:26px;gap:5px;padding:9px 0;
    background-image:repeating-linear-gradient(90deg, transparent, transparent calc(100%/7 - 1px), var(--line) calc(100%/7 - 1px), var(--line) calc(100%/7));}
  .bar{border-radius:7px;font-size:10.5px;font-weight:600;color:#04121f;display:flex;align-items:center;padding:0 9px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;box-shadow:inset 0 1px 0 rgba(255,255,255,.25);}
  .b-legal{background:linear-gradient(135deg,#94a3b8,#64748b);color:#0b1220;}
  .b-prod{background:linear-gradient(135deg,#5cc8fb,#0ea5e9);}
  .b-ai{background:linear-gradient(135deg,#a78bfa,#7c3aed);color:#fff;}
  .b-gtm{background:linear-gradient(135deg,#4ade80,#16a34a);color:#04210f;}
  .b-ops{background:linear-gradient(135deg,#fbbf24,#d97706);}
  .b-seller{background:linear-gradient(135deg,#fdba74,#ea580c);color:#1a0e03;}
  .b-mobile{background:linear-gradient(135deg,#f472b6,#db2777);color:#fff;}
  .b-pay{background:linear-gradient(135deg,#fbbf24,#d97706);color:#3a1d00;}
  .b-gate{background:repeating-linear-gradient(45deg,#fbbf24,#fbbf24 6px,#d97706 6px,#d97706 12px);color:#2a1500;}
  .b-soft{opacity:.5;}
  .months .gatecol{color:#fcd34d;}
  .milestones{display:grid;grid-template-columns:170px 1fr;border-bottom:1px solid var(--line);background:rgba(56,189,248,.03);}
  .ms-track{position:relative;display:grid;grid-template-columns:repeat(7,1fr);align-items:center;height:46px;}
  .ms{grid-row:1;justify-self:end;transform:translateX(50%);text-align:center;}
  .ms .dia{width:14px;height:14px;background:var(--sky);transform:rotate(45deg);margin:0 auto 4px;border:1px solid #fff3;}
  .ms.launch .dia{background:var(--red);width:18px;height:18px;}
  .ms.gate .dia{background:var(--amber);}
  .ms .lab{font-size:9.5px;color:var(--soft);font-weight:600;white-space:nowrap;}
  .ms.launch .lab{color:#fca5a5;}
  .ms.gate .lab{color:#fcd34d;}
  .foot{margin-top:20px;color:var(--dim);font-size:11.5px;text-align:center;}
  @media(max-width:760px){body{padding:14px;} .lane-label,.months div:first-child{font-size:11px;}}
</style>
</head>
