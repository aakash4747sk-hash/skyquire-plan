  <div class="brand">Sky<span>quire</span></div>
  <h1>Launch Timeline — Jun → Dec 19, 2026</h1>
  <div class="sub">Both verticals · web + native mobile · free at launch · solo founder + AI · ◆ = milestone · ▦ Sep = web-stability gate</div>
  <div class="legend">
    <span><i class="sw b-legal"></i> Legal &amp; Compliance</span>
    <span><i class="sw b-prod"></i> Product &amp; Eng (Web)</span>
    <span><i class="sw b-mobile"></i> Native Mobile</span>
    <span><i class="sw b-ai"></i> AI &amp; Data</span>
    <span><i class="sw b-gtm"></i> GTM &amp; Supply</span>
    <span><i class="sw b-seller"></i> Seller Platform</span>
    <span><i class="sw b-pay"></i> Payments (post-launch)</span>
  </div>

  <div class="chart">
    <div class="months">
      <div>Workstream</div><div>Jun</div><div>Jul</div><div>Aug</div><div class="gatecol">Sep ▦</div><div>Oct</div><div>Nov</div><div class="launchcol">Dec 🚀</div>
    </div>

    <!-- milestones -->
    <div class="milestones">
      <div class="lane-label" style="color:var(--dim);font-size:11px;text-transform:uppercase;letter-spacing:.08em;">Milestones</div>
      <div class="ms-track">
        <div class="ms" style="grid-column:2;"><div class="dia"></div><div class="lab">M0 · registered + validated</div></div>
        <div class="ms gate" style="grid-column:4;"><div class="dia"></div><div class="lab">GATE · both verticals web-stable</div></div>
        <div class="ms" style="grid-column:5;"><div class="dia"></div><div class="lab">M2 · native apps in beta</div></div>
        <div class="ms" style="grid-column:6;"><div class="dia"></div><div class="lab">M3 · store freeze + submitted</div></div>
        <div class="ms launch" style="grid-column:7;"><div class="dia"></div><div class="lab">🚀 LAUNCH Dec 19</div></div>
      </div>
    </div>

    <!-- Legal -->
    <div class="lane">
      <div class="lane-label"><span class="d" style="background:#64748b;"></span>Legal &amp; Compliance</div>
      <div class="track">
        <div class="bar b-legal" style="grid-column:1/2;grid-row:1;">SEBI / advisory check — confirm NOW</div>
        <div class="bar b-legal" style="grid-column:1/3;grid-row:2;">Finish Pvt Ltd · GST · Startup India</div>
        <div class="bar b-legal" style="grid-column:2/4;grid-row:3;">DPDP policy · ToS · fee agreement</div>
        <div class="bar b-legal" style="grid-column:7/8;grid-row:1;">Launch legal review</div>
      </div>
    </div>

    <!-- Product (Web) -->
    <div class="lane">
      <div class="lane-label"><span class="d" style="background:#0ea5e9;"></span>Product &amp; Eng (Web)</div>
      <div class="track">
        <div class="bar b-prod" style="grid-column:1/3;grid-row:1;">Harden MVP · lock shared architecture</div>
        <div class="bar b-prod" style="grid-column:2/4;grid-row:2;">SMB marketplace — finish &amp; polish</div>
        <div class="bar b-prod" style="grid-column:2/4;grid-row:3;">Corporate M&amp;A suite — finish &amp; polish</div>
        <div class="bar b-gate" style="grid-column:4/5;grid-row:1;">▦ WEB STABLE — feature freeze</div>
        <div class="bar b-prod b-soft" style="grid-column:5/7;grid-row:2;">Hardening · perf · security · a11y</div>
        <div class="bar b-prod" style="grid-column:7/8;grid-row:3;">Bug bash · GA</div>
      </div>
    </div>

    <!-- Native Mobile -->
    <div class="lane">
      <div class="lane-label"><span class="d" style="background:#db2777;"></span>Native Mobile (Expo)</div>
      <div class="track">
        <div class="bar b-mobile b-soft" style="grid-column:3/5;grid-row:1;">RN/Expo scaffold · auth · nav (early start)</div>
        <div class="bar b-mobile" style="grid-column:4/6;grid-row:2;">Buyer + seller flows on iOS &amp; Android</div>
        <div class="bar b-mobile" style="grid-column:5/6;grid-row:3;">Corporate flows · push · polish</div>
        <div class="bar b-mobile" style="grid-column:6/7;grid-row:1;">Store submit + review buffer</div>
        <div class="bar b-mobile b-soft" style="grid-column:7/8;grid-row:2;">Day-1 patch window</div>
      </div>
    </div>

    <!-- AI -->
    <div class="lane">
      <div class="lane-label"><span class="d" style="background:#7c3aed;"></span>AI &amp; Data</div>
      <div class="track">
        <div class="bar b-ai" style="grid-column:1/3;grid-row:1;">Health score · Aria · pgvector (live)</div>
        <div class="bar b-ai" style="grid-column:4/6;grid-row:2;">DD assistant — harden beta</div>
        <div class="bar b-ai b-soft" style="grid-column:6/8;grid-row:1;">Analytics / big-data base (v1.x)</div>
      </div>
    </div>

    <!-- GTM & Supply -->
    <div class="lane">
      <div class="lane-label"><span class="d" style="background:#16a34a;"></span>GTM &amp; Supply</div>
      <div class="track">
        <div class="bar b-gtm" style="grid-column:1/3;grid-row:1;">Validation · 20 interviews</div>
        <div class="bar b-gtm" style="grid-column:2/8;grid-row:2;">SEED SUPPLY — 50+ SMB listings + corporate mandates</div>
        <div class="bar b-gtm" style="grid-column:2/8;grid-row:3;">Waitlist 500+ · content engine · CA/advisor partnerships</div>
        <div class="bar b-gtm" style="grid-column:6/8;grid-row:1;">PR + launch campaign</div>
      </div>
    </div>

    <!-- Seller Platform -->
    <div class="lane">
      <div class="lane-label"><span class="d" style="background:#ea580c;"></span>Seller Platform</div>
      <div class="track">
        <div class="bar b-seller" style="grid-column:1/3;grid-row:1;">Submission app + verify + publish (live)</div>
        <div class="bar b-seller b-soft" style="grid-column:4/6;grid-row:2;">Seller flows folded into native mobile</div>
      </div>
    </div>

    <!-- Payments (post-launch) -->
    <div class="lane">
      <div class="lane-label"><span class="d" style="background:#d97706;"></span>Payments (post-launch)</div>
      <div class="track">
        <div class="bar b-pay b-soft" style="grid-column:7/8;grid-row:1;">Razorpay KYC + fees → v1.x</div>
        <div class="bar b-pay b-soft" style="grid-column:7/8;grid-row:2;">Escrow · Aadhaar eSign → v2</div>
      </div>
    </div>
  </div>

  <div class="foot">Skyquire · Launch Timeline (Gantt) · generated Jun 18, 2026 · faded bars = stretch/parallel work</div>
